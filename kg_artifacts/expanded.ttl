:birthYear a owl:DatatypeProperty ;
    rdfs:label "birthYear"@en ;
    rdfs:comment "Année de naissance de l'athlète"@fr ;
    rdfs:domain :Athlete ;
    rdfs:range xsd:integer .

:fullName a owl:DatatypeProperty ;
    rdfs:label "fullName"@en ;
    rdfs:comment "Nom complet"@fr ;
    rdfs:domain :Person ;
    rdfs:range xsd:string .

:hasCompeted a owl:ObjectProperty ;
    rdfs:label "hasCompeted"@en ;
    rdfs:comment "L'athlète a concouru contre cet autre athlète (inféré SWRL)"@fr ;
    rdfs:domain :Athlete ;
    rdfs:range :Athlete .

:hostedBy a owl:ObjectProperty ;
    rdfs:label "hostedBy"@en ;
    rdfs:comment "La compétition est organisée par ce pays"@fr ;
    rdfs:domain :Competition ;
    rdfs:range :Country .

:locatedIn a owl:ObjectProperty ;
    rdfs:label "locatedIn"@en ;
    rdfs:comment "La compétition se déroule dans cette ville"@fr ;
    rdfs:domain :Competition ;
    rdfs:range :City .

:memberOfTeam a owl:ObjectProperty ;
    rdfs:label "memberOfTeam"@en ;
    rdfs:comment "L'athlète est membre de cette équipe"@fr ;
    rdfs:domain :Athlete ;
    rdfs:range :Team ;
    owl:equivalentProperty wdt:P54 .

:ontologie a owl:Ontology ;
    rdfs:label "Sports & Competitions Ontology"@en ;
    rdfs:comment "Ontologie pour les sportifs, compétitions, disciplines et palmarès."@fr .

:participatedIn a owl:ObjectProperty ;
    rdfs:label "participatedIn"@en ;
    rdfs:comment "L'athlète a participé à cette compétition"@fr ;
    rdfs:domain :Athlete ;
    rdfs:range :Competition ;
    owl:equivalentProperty wdt:P1344 .

:practicesSport a owl:ObjectProperty ;
    rdfs:label "practicesSport"@en ;
    rdfs:comment "L'athlète pratique ce sport"@fr ;
    rdfs:domain :Athlete ;
    rdfs:range :Sport ;
    owl:equivalentProperty wdt:P641 .

:represents a owl:ObjectProperty ;
    rdfs:label "represents"@en ;
    rdfs:comment "L'athlète représente ce pays"@fr ;
    rdfs:domain :Athlete ;
    rdfs:range :Country ;
    owl:equivalentProperty wdt:P27 .

:sameNationality a owl:ObjectProperty ;
    rdfs:label "sameNationality"@en ;
    rdfs:comment "Les deux athlètes représentent le même pays (inféré SWRL)"@fr ;
    rdfs:domain :Athlete ;
    rdfs:range :Athlete .

:teamRepresents a owl:ObjectProperty ;
    rdfs:label "teamRepresents"@en ;
    rdfs:comment "L'équipe représente ce pays"@fr ;
    rdfs:domain :Team ;
    rdfs:range :Country .

:wonMedal a owl:ObjectProperty ;
    rdfs:label "wonMedal"@en ;
    rdfs:comment "L'athlète a remporté cette médaille"@fr ;
    rdfs:domain :Athlete ;
    rdfs:range :Medal ;
    owl:equivalentProperty wdt:P166 .

:year a owl:DatatypeProperty ;
    rdfs:label "year"@en ;
    rdfs:comment "Année de la compétition"@fr ;
    rdfs:domain :Competition ;
    rdfs:range xsd:integer .

